                    <div><div class="bg-slate-800 text-white font-black text-xs px-3 py-2 uppercase">A. Patient Information *</div><div class="yf-box"><div class="grid grid-cols-4 gap-3 mb-3"><div><span class="yf-label">1. Initials *</span><span class="yf-field">${p.patientName.split(' ').map(n=>n[0]).join('.')}</span></div><div><span class="yf-label">2. Age *</span><span class="yf-field">${p.age} yrs</span></div><div><span class="yf-label">3. Gender *</span><div class="flex gap-2 mt-1 text-xs font-bold"><span><span class="cb ${p.gender==='Male'?'on':''}"></span>M</span><span><span class="cb ${p.gender==='Female'?'on':''}"></span>F</span></div></div><div><span class="yf-label">4. Weight</span><span class="yf-field">${p.weight}</span></div></div><div><span class="yf-label">12. Investigations</span><span class="yf-field" style="min-width:280px">Adherence: ${taken}/7 taken, ${missed} missed. Digital monitoring via MediRoom PV. Room: ${p.code}</span></div></div></div>
                    <div><div class="bg-slate-800 text-white font-black text-xs px-3 py-2 uppercase">B. Suspected Adverse Reaction *</div><div class="yf-box space-y-3"><div class="grid grid-cols-3 gap-3"><div><span class="yf-label">5. Start Date *</span><span class="yf-field">${fmtDMY(firstTs)}</span></div><div><span class="yf-label">6. Stop Date</span><span class="yf-field">Ongoing</span></div><div><span class="yf-label">15. Outcome</span><div class="flex gap-2 mt-1 text-xs font-bold"><span><span class="cb"></span>Recovered</span><span><span class="cb on"></span>Recovering</span></div></div></div><div><span class="yf-label">7. Describe Event *</span><div class="border border-slate-300 rounded p-3 mt-1 bg-slate-50 text-xs leading-relaxed"><strong>Symptoms:</strong> ${symDesc}.<br>${pos.map(([k,s])=>`${symLabel(k)} at ${fmt(s.ts)}.`).join(' ')}<br><strong>Clinical note:</strong> ${p.note}</div></div><div><span class="yf-label">13. Medical History</span><div class="border border-slate-300 rounded p-3 mt-1 bg-slate-50 text-xs">${p.diagnosis}</div></div><div><span class="yf-label">14. Seriousness</span><div class="grid grid-cols-3 gap-2 mt-1 text-xs font-bold"><span><span class="cb"></span>Death</span><span><span class="cb"></span>Congenital</span><span><span class="cb ${pos.length>0?'on':''}"></span>Life Threatening</span><span><span class="cb"></span>Disability</span><span><span class="cb"></span>Hospitalization</span><span><span class="cb on"></span>Medically Important</span></div></div></div></div>
                    <div><div class="bg-slate-800 text-white font-black text-xs px-3 py-2 uppercase">C. Suspected Medication(s) *</div><div class="mt-2 overflow-x-auto"><table class="yf-table"><thead><tr><th>No.</th><th>Drug</th><th>Dose</th><th>Route</th><th>Frequency</th><th>Indication</th><th>Causality</th></tr></thead><tbody>${(p.drugs||[]).map((rx,i)=>`<tr ${rx.name===p.suspectedDrug?'style="background:#fff1f2;font-weight:700"':''}><td>${i+1}${rx.name===p.suspectedDrug?' ★':''}</td><td>${rx.name}${rx.name===p.suspectedDrug?' <span style="font-size:8px;background:#dc2626;color:white;padding:1px 4px;border-radius:3px">SUSPECTED</span>':''}</td><td>${rx.dose}</td><td>Oral</td><td>${rx.freq}</td><td>${p.diagnosis.split(',')[0]||'Prescribed'}</td><td>${rx.name===p.suspectedDrug?ctext:'—'}</td></tr>`).join('')}</tbody></table></div><div class="mt-2 p-3 border border-slate-200 rounded bg-slate-50 text-xs"><span class="yf-label" style="display:inline;margin-right:6px">9. Action:</span>Dose not changed &nbsp;<span class="yf-label" style="display:inline;margin-right:4px">10. Rechallenge:</span>Unknown</div></div>
                    <div><div class="bg-slate-800 text-white font-black text-xs px-3 py-2 uppercase">D. Reporter Details *</div><div class="yf-box"><div class="grid grid-cols-2 gap-5"><div><span class="yf-label">16. Name & Address *</span><div class="border border-slate-300 rounded p-3 mt-1 bg-slate-50 space-y-2 text-xs text-slate-400"><div class="border-b border-slate-300 pb-1">Dr. ${p.doctorName||'_______________'}</div><div class="border-b border-slate-300 pb-1">Hospital: ${p.doctorName?'(on file)':'_______________'}</div><div class="border-b border-slate-300 pb-1">Email: _______________________</div><div class="border-b border-slate-300 pb-1">Contact: _____________________</div></div></div><div class="space-y-3"><div><span class="yf-label">Occupation</span><div class="flex gap-2 mt-1 text-xs font-bold"><span><span class="cb on"></span>Physician</span><span><span class="cb"></span>Pharmacist</span></div></div><div><span class="yf-label">17. Date *</span><span class="yf-field">${fmtDMY()}</span></div><div><span class="yf-label">Signature</span><div class="border-b border-slate-400 mt-6 w-36"></div></div></div></div></div></div>
                    <div class="border-2 border-indigo-200 rounded-xl p-4 bg-indigo-50"><p class="text-[9px] font-black text-indigo-700 uppercase mb-2">MediRoom Addendum</p><div class="grid grid-cols-2 gap-3 text-xs"><div><p class="font-black text-slate-600">Naranjo Score</p><p class="font-bold">${ctext}</p></div><div><p class="font-black text-slate-600">Patient Room</p><p class="font-bold">${p.code}</p></div><div><p class="font-black text-slate-600">Onset</p><p class="font-bold">${fmtDMY(firstTs)}</p></div><div><p class="font-black text-slate-600">Adherence</p><p class="font-bold">${taken}/7 taken</p></div><div class="col-span-2"><p class="font-black text-slate-600 mb-1">All Symptoms</p>${Object.entries(p.symptoms||{}).map(([k,s])=>`<p>${symLabel(k)}: <strong class="${s.value===true?'text-rose-700':s.value===false?'text-emerald-700':'text-slate-400'}">${s.value===true?'POS':s.value===false?'NEG':'PENDING'}</strong>${s.ts?' · '+fmt(s.ts):''}</p>`).join('')}</div></div></div>
                    <div class="bg-slate-50 border border-slate-200 rounded-xl p-3 text-center text-[10px] text-slate-500">
                        Confidentiality: Patient identity protected. No legal implication on reporter.<br>
                        <strong>Submit: pvpi.ipc@gov.in · AMC list: ipc.gov.in/PvPI · Generated via MediRoom</strong>
                    </div>
                </div>
            </div>
        </div>`;
    }
}

window.app = new App();
</script>
</body>
</html>
