function suggestQuestions(drug) {
    const k = drug.toLowerCase().trim();
    if (DRUG_QUESTIONS[k]) return [...DRUG_QUESTIONS[k]];
    for (const [key,qs] of Object.entries(DRUG_QUESTIONS)) {
        if (key!=='default' && (k.includes(key)||key.includes(k))) return [...qs];
    }
    return [...DRUG_QUESTIONS.default];
}

