    async createPatient() {
        const name = document.getElementById('pn-name').value.trim();
        const age = document.getElementById('pn-age').value.trim();
        const gender = document.getElementById('pn-gender').value;
        const weight = document.getElementById('pn-weight').value.trim()||'Not recorded';
        const ec = document.getElementById('pn-ec').value.trim()||'Not provided';
        const diagnosis = document.getElementById('pn-diagnosis').value.trim();
        const note = document.getElementById('pn-note').value.trim()||'Monitor for adverse drug reactions.';
        const suspected = document.getElementById('pn-suspected').value.trim();
        const err = document.getElementById('pn-err');
        err.classList.add('hidden');

        if (!name||!age||!gender||!diagnosis||!suspected) { err.textContent='Fill all required fields.'; err.classList.remove('hidden'); return; }

        const drugs = [];
        document.querySelectorAll('.drug-row').forEach(row => {
            const n=row.querySelector('.drug-name').value.trim();
            const d=row.querySelector('.drug-dose').value.trim();
            const f=row.querySelector('.drug-freq').value.trim();
            if(n) drugs.push({id:'m'+Date.now()+Math.random(),name:n,dose:d||'As prescribed',freq:f||'As directed',delivered:false,stocked:true});
        });
        if (drugs.length===0) { err.textContent='Add at least one medication.'; err.classList.remove('hidden'); return; }

        // Generate unique room code
        let code = genCode();
        for (let i=0;i<10;i++) {
            const ex = await getDoc(doc(this.db,'rooms',code));
            if (!ex.exists()) break;
            code = genCode();
        }

        // Collect questionnaire — use custom if doctor built one, else auto-suggest
        let questions = (this._currentQuestions || []).filter(q=>q.trim());
        if (questions.length === 0) questions = suggestQuestions(suspected);
        // Build symptom keys from questions (one per question, keyed q0..qN)
        const symptoms = {};
        questions.forEach((_,i) => { symptoms['q'+i] = {value:null, ts:null}; });

        const room = {
            code, doctorPhone:this.user.phone, doctorName:this.user.name,
            patientName:name, patientPhone:'', age:parseInt(age), gender, weight,
            diagnosis, note, suspectedDrug:suspected,
            status:'Active - Outpatient Monitoring',
            emergencyContact:ec, emergencyNotified:false,
            drugs,
            questionnaire: questions,
            symptoms,
            adherence:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map(day=>({day,s:'pending'})),
            naranjo:{}, qi:0, createdAt:new Date().toISOString()
        };
        this._currentQuestions = null;

        await this.saveDoc('rooms', code, room);
        // Post welcome message
        await this.postChat(code,'system','System',`Room created for ${name} by Dr. ${this.user.name}. Room code: ${code}`);
        await this.loadMyPatients();
        this.showRoomCodeModal(name, code);
    }

