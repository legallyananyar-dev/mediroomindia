    async setPharmacistCode() {
        const code = prompt('Set a pharmacist access code (min 4 characters):');
        if (!code || code.length < 4) { alert('Code must be at least 4 characters.'); return; }
        this.user.pharmacistCode = code;
        await this.saveDoc('doctors', this.user.phone, this.user);
        this.render();
        alert(`Pharmacist code set to: ${code}\nShare this with your pharmacist.`);
    }

    async loginPharmacist() {
        const code = prompt('Enter pharmacist access code:');
        if (!code) return;
        // Check global default code
        if (code === PHARMACIST_CODE) {
            this.role = 'pharmacist';
            await this.loadAllPatients();
            this.showNav('Pharmacist');
            this.view = 'pharmacist';
            this.render();
            return;
        }
        // Check all doctors for a matching pharmacist code
        try {
            const snap = await getDocs(collection(this.db, 'doctors'));
            let matchedDoctor = null;
            snap.forEach(d => {
                const data = d.data();
                if (data.pharmacistCode && data.pharmacistCode === code) {
                    matchedDoctor = data;
                }
            });
            if (matchedDoctor) {
                this.role = 'pharmacist';
                this._linkedDoctor = matchedDoctor;
                await this.loadAllPatients();
                this.showNav('Pharmacist');
                this.view = 'pharmacist';
                this.render();
            } else {
                alert('Incorrect code. Please check with your doctor.');
            }
        } catch(e) {
            alert('Incorrect code.');
        }
    }

