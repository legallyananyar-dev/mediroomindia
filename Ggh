    vPharmacistInventory() {
        // Aggregate all drugs across all patients
        const allDrugs = {};
        this.patients.forEach(pt => {
            (pt.drugs||[]).forEach(rx => {
                const key = rx.name.toLowerCase().trim();
                if (!allDrugs[key]) {
                    allDrugs[key] = {
                        name: rx.name,
                        patients: [],
                        totalDispensed: 0,
                        totalPending: 0,
                        hasAdrFlag: false,
                        adrCleared: false
                    };
                }
                allDrugs[key].patients.push({ patientName:pt.patientName, code:pt.code, dose:rx.dose, freq:rx.freq, delivered:rx.delivered, stocked:rx.stocked });
                if (rx.delivered) allDrugs[key].totalDispensed++;
                else allDrugs[key].totalPending++;
                const isSuspected = rx.name === pt.suspectedDrug;
                const hasFlag = Object.values(pt.symptoms||{}).some(s=>s.value===true);
                if (isSuspected && hasFlag) allDrugs[key].hasAdrFlag = true;
                if (rx.adrCleared) allDrugs[key].adrCleared = true;
            });
