    async patientRegister() {
        const name = document.getElementById('pr-name').value.trim();
        const phone = document.getElementById('pr-phone').value.trim();
        const code = document.getElementById('pr-code').value.trim();
        const err = document.getElementById('pr-err');
        err.classList.add('hidden');
        if (!name||phone.length!==10||code.length!==6) { err.textContent='Please fill all fields correctly.'; err.classList.remove('hidden'); return; }
        const fullPhone = '+91'+phone;
        // Verify room code exists
        const roomSnap = await getDoc(doc(this.db, 'rooms', code));
        if (!roomSnap.exists()) { err.textContent='Room code not found. Check with your doctor.'; err.classList.remove('hidden'); return; }
        // Check not already registered
        const existing = await getDoc(doc(this.db, 'patients', fullPhone));
        if (existing.exists()) { err.textContent='This number is already registered. Please login.'; err.classList.remove('hidden'); return; }
        // Save patient profile
        const profile = { name, phone:fullPhone, roomCode:code, registeredAt:new Date().toISOString() };
        await this.saveDoc('patients', fullPhone, profile);
        // Update room with phone link
        await this.saveDoc('rooms', code, { patientPhone:fullPhone, patientName:name });
        // Post welcome message to room
        await this.postChat(code, 'system', 'System', `${name} has joined the room.`);
        this.user = profile; this.role = 'patient';
        this.currentPatientCode = code;
        this.currentPatient = roomSnap.data();
        this.showNav(name.split(' ')[0]);
        this.subscribeRoom(code);
        this.subscribeChat(code);
        this.view = 'patient-home';
        this.render();
    }

    // ── FIREBASE SUBSCRIPTIONS ─────────────────────────────────────────────
    subscribeRoom(code) {
        if (this.unsub) this.unsub();
        this.unsub = onSnapshot(doc(this.db, 'rooms', code), snap => {
            if (snap.exists()) { this.currentPatient = snap.data(); this.render(); }
        });
    }

    subscribeChat(code) {
        if (this.unsubChat) this.unsubChat();
        // We'll store chat in a subcollection: rooms/{code}/chat
        // Using onSnapshot with ordering
        this.unsubChat = onSnapshot(
            collection(this.db, 'rooms', code, 'chat'),
            snap => {
                this.chatMessages = snap.docs
                    .map(d => ({id:d.id, ...d.data()}))
                    .sort((a,b) => (a.ts||0) - (b.ts||0));
                // Only re-render if we're in common room or patient home
                if (['common-room','patient-home'].includes(this.view)) this.render();
            }
        );
    }

    async postChat(roomCode, role, senderName, content, type='text') {
        try {
            await addDoc(collection(this.db, 'rooms', roomCode, 'chat'), {
                role, senderName, content, type, ts: Date.now()
            });
        } catch(e) { console.warn('Chat post failed:', e); }
    }

    // ── DOCTOR DASHBOARD ───────────────────────────────────────────────────
    async loadMyPatients() {
        if (!this.db || !this.user) return;
        try {
            const snap = await getDocs(collection(this.db, 'rooms'));
            this.patients = snap.docs
                .map(d => ({code:d.id, ...d.data()}))
                .filter(p => p.doctorPhone === this.user.phone)
                .sort((a,b) => new Date(b.createdAt||0) - new Date(a.createdAt||0));
        } catch(e) { console.warn(e); }
    }

    async loadAllPatients() {
        if (!this.db) return;
        try {
            const snap = await getDocs(collection(this.db, 'rooms'));
            this.patients = snap.docs.map(d => ({code:d.id, ...d.data()}));
        } catch(e) {}
    }

