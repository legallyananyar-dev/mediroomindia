    async generateQuestions() {
        const suspected = document.getElementById('pn-suspected').value.trim();
        if (!suspected) { alert('Please enter the suspected drug name first.'); return; }

        const section = document.getElementById('questionnaire-section');
        const list = document.getElementById('question-list');
        const loadingEl = document.getElementById('q-translate-loading');
        if (!section || !list) return;
        section.classList.remove('hidden');

        // Show loading state
        if (loadingEl) { loadingEl.textContent = GROQ_KEY ? '🤖 Generating AI questions for ' + suspected + '…' : '📋 Loading preset questions…'; loadingEl.classList.remove('hidden'); }
        list.innerHTML = '';

        let questions = [];

        if (GROQ_KEY) {
            try {
                const lang = this._lang || 'en';
                const langInstruction = lang !== 'en' ? ` Translate questions to ${LANGUAGES[lang]?.name || lang}.` : '';
                const result = await this.callClaude(
                    `Generate 6 specific daily patient monitoring questions for someone taking "${suspected}". Focus on known adverse drug reactions and side effects of this drug. Return ONLY a JSON array of 6 strings, no explanation, no markdown.${langInstruction}`,
                    'You are a clinical pharmacovigilance expert. Generate precise ADR monitoring questions. Return only a valid JSON array of strings.'
                );
                const clean = result.replace(/```json|```/g,'').trim();
                questions = JSON.parse(clean);
                if (!Array.isArray(questions)) throw new Error('Not an array');
            } catch(e) {
                console.warn('AI question generation failed, using presets:', e);
                questions = suggestQuestions(suspected);
            }
        } else {
            questions = suggestQuestions(suspected);
            // Still try translation if non-English selected
            const lang = this._lang || 'en';
            if (lang !== 'en') {
                try { questions = await this.translateQuestions(questions, lang); } catch(e) {}
            }
        }

        if (loadingEl) loadingEl.classList.add('hidden');
        this._currentQuestions = questions;
        this._renderQuestionList();
    }
        const badge = document.createElement('div');
        badge.className = 'mt-2 p-3 bg-emerald-50 border border-emerald-200 rounded-xl text-xs font-bold text-emerald-700';
        badge.textContent = `✓ ${this._currentQuestions.length} questions suggested for ${suspected}${lang!=='en'?' ('+( LANGUAGES[lang]?.name||lang)+')':''} . Edit as needed before enrolling.`;
        badge.id = 'q-badge';
        const existing = document.getElementById('q-badge');
        if (existing) existing.remove();
        section.parentNode.insertBefore(badge, section);
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    _renderQuestionList() {
        const list = document.getElementById('question-list');
        if (!list || !this._currentQuestions) return;
        list.innerHTML = this._currentQuestions.map((q, i) => `
        <div class="flex items-start gap-2 p-3 bg-slate-50 border border-slate-200 rounded-xl" id="q-item-${i}">
            <span class="text-[9px] font-black text-indigo-500 bg-indigo-50 rounded-lg px-2 py-1 flex-shrink-0 mt-0.5">Q${i+1}</span>
            <input type="text" value="${q.replace(/"/g, '&quot;')}"
                class="flex-1 bg-transparent outline-none text-sm font-medium text-slate-700 border-b border-slate-200 pb-1 focus:border-indigo-400"
                onchange="app._currentQuestions[${i}]=this.value">
