    async sendChatMessage() {
        const el = document.getElementById('chat-input');
        if (!el||!el.value.trim()) return;
        const content = el.value.trim();
        el.value = '';
        const senderName = this.role==='doctor'?('Dr. '+this.user.name):this.role==='patient'?(this.user.name):('Pharmacist');
        await this.postChat(this.currentPatientCode, this.role, senderName, content);
    }

    async answerQ(k, v, questionText) {
        const p = this.currentPatient;
        if (!p) return;
        if (!p.symptoms) p.symptoms = {};
        p.symptoms[k] = {value:v, ts:new Date().toISOString(), question: questionText||k};
        p.qi = (p.qi||0)+1;
        // Post to chat with the actual question text
        const shortQ = questionText ? (questionText.length > 60 ? questionText.substring(0,57)+'...' : questionText) : k;
        const msg = v
            ? `⚠ YES — ${shortQ}`
            : `✓ NO — ${shortQ}`;
        await this.postChat(this.currentPatientCode, 'patient', this.user.name, msg, 'symptom');
        await this.saveDoc('rooms', this.currentPatientCode, p);
    }

    async resetQ() {
        const p = this.currentPatient;
        if (!p) return;
        p.qi = 0;
        // Rebuild symptoms object from questionnaire
        const questionnaire = (p.questionnaire && p.questionnaire.length > 0)
            ? p.questionnaire
            : suggestQuestions(p.suspectedDrug || 'default');
        const symptoms = {};
        questionnaire.forEach((_, i) => { symptoms['q'+i] = {value:null, ts:null, question: questionnaire[i]}; });
        p.symptoms = symptoms;
        await this.saveDoc('rooms', this.currentPatientCode, p);
    }

    async toggleDay(i) {
        const p = this.currentPatient;
        if (!p) return;
        const c={pending:'taken',taken:'missed',missed:'pending'};
        const prev = p.adherence[i].s;
        p.adherence[i].s = c[prev];
        const dayLabel = p.adherence[i].day;
        const newStatus = p.adherence[i].s;
        await this.postChat(this.currentPatientCode,'patient',this.user.name,`${dayLabel}: Medication marked as ${newStatus}`,'adherence');
        await this.saveDoc('rooms', this.currentPatientCode, p);
    }

    async toggleDelivery(drugId) {
        const p = this.currentPatient;
        if (!p) return;
        const drug = p.drugs.find(d=>d.id===drugId);
        if (!drug) return;
        drug.delivered = !drug.delivered;
        await this.postChat(this.currentPatientCode,'pharmacist','Pharmacist',`${drug.name}: ${drug.delivered?'Delivered to patient ✓':'Marked as pending'}`, 'delivery');
        await this.saveDoc('rooms', this.currentPatientCode, p);
    }

    async notifyEmergency() {
        const p = this.currentPatient;
        if (!p) return;
        p.emergencyNotified = true;
        await this.postChat(this.currentPatientCode,'doctor','Dr. '+this.user.name,`🚨 Emergency contact (${p.emergencyContact}) has been notified by physician.`,'emergency');
        await this.saveDoc('rooms', this.currentPatientCode, p);
    }

