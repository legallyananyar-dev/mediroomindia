                            ${d.adrCleared ? '<span class="text-[8px] bg-emerald-100 text-emerald-700 border border-emerald-200 px-2 py-0.5 rounded-full font-black">ADR CLEARED</span>' : ''}
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="text-right">
                                <p class="text-[9px] font-black text-slate-400 uppercase">Dispensed</p>
                                <p class="font-black text-emerald-600">${d.totalDispensed}</p>
                            </div>
                            <div class="text-right">
                                <p class="text-[9px] font-black text-slate-400 uppercase">Pending</p>
