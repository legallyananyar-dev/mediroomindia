    async answerNaranjo(id, ans) {
        const p = this.currentPatient;
        if (!p) return;
        if (!p.naranjo) p.naranjo={};
        p.naranjo[id] = ans;
        await this.saveDoc('rooms', this.currentPatientCode, p);
        this.render();
    }

