    async toggleStock(roomCode, drugId) {
        // Pharmacist needs to enter the room to toggle stock
        const snap = await getDoc(doc(this.db, 'rooms', roomCode));
        if (!snap.exists()) return;
        const room = snap.data();
        const drug = (room.drugs||[]).find(d=>d.id===drugId);
        if (!drug) return;
        drug.stocked = !drug.stocked;
        await this.saveDoc('rooms', roomCode, room);
        // Update local patients list
        const idx = this.patients.findIndex(p=>p.code===roomCode);
        if (idx !== -1) this.patients[idx] = room;
        this.render();
    }

    async clearAdr(roomCode, drugName) {
        const confirmed = confirm(`Mark ADR for "${drugName}" as cleared and safe to continue dispensing?\n\nThis will log the clearance to the patient room and notify the doctor via the chat.`);
        if (!confirmed) return;
        const snap = await getDoc(doc(this.db, 'rooms', roomCode));
        if (!snap.exists()) return;
        const room = snap.data();
        const drug = (room.drugs||[]).find(d=>d.name===drugName);
        if (drug) {
            drug.adrCleared = true;
            drug.adrClearedAt = new Date().toISOString();
        }
        room.adrClearanceLog = room.adrClearanceLog || [];
        room.adrClearanceLog.push({ drug:drugName, clearedAt:new Date().toISOString(), clearedBy:'Pharmacist' });
        await this.saveDoc('rooms', roomCode, room);
        // Post to room chat
        try {
            await addDoc(collection(this.db, 'rooms', roomCode, 'chat'), {
                role:'pharmacist', senderName:'Pharmacist',
                content:`✅ ADR clearance for ${drugName}: Inventory reviewed and cleared. Safe to continue dispensing. Logged at ${new Date().toLocaleString('en-IN')}.`,
                type:'adr-clearance', ts:Date.now()
            });
        } catch(e) {}
        const idx = this.patients.findIndex(p=>p.code===roomCode);
        if (idx !== -1) this.patients[idx] = room;
        this.render();
    }

