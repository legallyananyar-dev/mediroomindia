    // ── AI HELPERS ─────────────────────────────────────────────────────────
    async callClaude(prompt, systemPrompt='') {
        if (!GROQ_KEY) throw new Error('No API key');
        const messages = [];
        if (systemPrompt) messages.push({ role:'system', content: systemPrompt });
        messages.push({ role:'user', content: prompt });
        const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
            method:'POST',
            headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+GROQ_KEY },
            body: JSON.stringify({ model:'llama-3.3-70b-versatile', max_tokens:1000, messages })
        });
        const data = await res.json();
        if (data.error) throw new Error(data.error.message);
        return data.choices?.[0]?.message?.content || '';
    }

    async translateQuestions(questions, targetLang) {
        if (!GROQ_KEY || targetLang === 'en') return questions;
        const langName = LANGUAGES[targetLang]?.name || targetLang;
        try {
            const result = await this.callClaude(
                `Translate these medical questionnaire questions to ${langName}. Return ONLY a JSON array of strings, no explanation:\n${JSON.stringify(questions)}`,
                'You are a medical translator. Return only valid JSON array, no markdown or extra text.'
            );
            const clean = result.replace(/```json|```/g,'').trim();
            return JSON.parse(clean);
        } catch(e) { console.warn('Translation failed:', e); return questions; }
    }

    async scanReportWithAI(base64Image, mimeType) {
        if (!GROQ_KEY) throw new Error('No API key configured');
        const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
            method:'POST',
            headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+GROQ_KEY },
            body: JSON.stringify({
                model:'meta-llama/llama-4-scout-17b-16e-instruct',
                max_tokens:1000,
                messages:[
                    { role:'system', content:'You are a medical record extractor. Extract structured data from medical reports/prescriptions and return ONLY valid JSON with no markdown.' },
                    { role:'user', content:[
                        { type:'image_url', image_url:{ url:`data:${mimeType};base64,${base64Image}` }},
                        { type:'text', text:'Extract patient information from this medical document. Return ONLY valid JSON with no markdown: {"patientName":"","age":"","gender":"","diagnosis":"","medications":[{"name":"","dose":"","freq":""}],"clinicalNote":""}. Use empty string if not found.' }
                    ]}
                ]
            })
        });
        const data = await res.json();
        if (data.error) throw new Error(data.error.message);
        const text = data.choices?.[0]?.message?.content || '';
        const clean = text.replace(/```json|```/g,'').trim();
        return JSON.parse(clean);
    }

