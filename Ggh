    async sendWhatsAppQuestionnaire(patient) {
        const token = localStorage.getItem('mediroom_wa_token');
        const phoneId = localStorage.getItem('mediroom_wa_phone_id');
        const phone = (patient.patientPhone||'').replace(/[^0-9]/g,'');
        if (!phone) { alert('No phone number on file for this patient.'); return; }
        if (!token || !phoneId) {
            // Fallback to WhatsApp Web link
            const questions = (patient.questionnaire||[]).map((q,i)=>`${i+1}. ${q}`).join('\n');
            const msg = encodeURIComponent(`🏥 *MediRoom Daily Check-in*\nHi ${patient.patientName}, please answer today's questions:\n\n${questions}\n\nRoom Code: ${patient.code}`);
            window.open(`https://wa.me/${phone}?text=${msg}`, '_blank');
            return;
        }
        const questions = (patient.questionnaire||[]).map((q,i)=>`${i+1}. ${q}`).join('\n');
        try {
            const res = await fetch(`https://graph.facebook.com/v18.0/${phoneId}/messages`, {
                method:'POST',
                headers:{ 'Content-Type':'application/json', 'Authorization':'Bearer '+token },
                body: JSON.stringify({
                    messaging_product:'whatsapp', to:phone, type:'text',
                    text:{ body:`🏥 *MediRoom Daily Check-in*\nHi ${patient.patientName}, please answer today's health questions:\n\n${questions}\n\nRoom Code: *${patient.code}*\nReply with your answers or open MediRoom to respond.` }
                })
            });
            const data = await res.json();
            if (data.error) throw new Error(data.error.message);
            alert(`✅ Questionnaire sent to ${patient.patientName} via WhatsApp!`);
        } catch(e) {
            alert(`Failed to send: ${e.message}\nOpening WhatsApp Web instead...`);
            const msg = encodeURIComponent(`🏥 *MediRoom Daily Check-in*\nHi ${patient.patientName}:\n\n${questions}\n\nRoom: ${patient.code}`);
            window.open(`https://wa.me/${phone}?text=${msg}`, '_blank');
        }
    }

