    handleReportDrop(e) {
        const file = e.dataTransfer.files[0];
        if (file) this.handleReportFile(file);
    }

    handleReportFile(file) {
        if (!file) return;
        this._ehrFile = file;
        const preview = document.getElementById('ehr-preview');
        const img = document.getElementById('ehr-img');
        const pdfNotice = document.getElementById('ehr-pdf-notice');
        const btn = document.getElementById('ehr-extract-btn');
        if (file.type.startsWith('image/')) {
            img.src = URL.createObjectURL(file);
            img.classList.remove('hidden');
            pdfNotice.classList.add('hidden');
        } else {
            img.classList.add('hidden');
            pdfNotice.classList.remove('hidden');
        }
        preview.classList.remove('hidden');
        btn.classList.remove('hidden');
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    async extractReport() {
        const file = this._ehrFile;
        if (!file) return;
        const loading = document.getElementById('ehr-loading');
        const results = document.getElementById('ehr-results');
        const errEl = document.getElementById('ehr-error');
        const btn = document.getElementById('ehr-extract-btn');
        errEl.classList.add('hidden');
        results.classList.add('hidden');

        if (!GROQ_KEY) {
            // No AI — just go to add patient with empty form
            this.go('add-patient');
            return;
        }

        loading.classList.remove('hidden');
        btn.disabled = true;
        try {
            const base64 = await new Promise((res,rej)=>{
                const r = new FileReader();
                r.onload = ()=>res(r.result.split(',')[1]);
                r.onerror = ()=>rej(new Error('Read failed'));
                r.readAsDataURL(file);
            });
            const extracted = await this.scanReportWithAI(base64, file.type);
            this._ehrExtracted = extracted;
            // Populate fields
            document.getElementById('ehr-name').value = extracted.patientName||'';
            document.getElementById('ehr-age').value = extracted.age||'';
            document.getElementById('ehr-diagnosis').value = extracted.diagnosis||'';
            document.getElementById('ehr-note').value = extracted.clinicalNote||'';
            const medsEl = document.getElementById('ehr-meds');
            medsEl.innerHTML = (extracted.medications||[]).map((m,i)=>`
            <div class="grid grid-cols-3 gap-2">
                <input type="text" value="${m.name||''}" placeholder="Drug" class="px-3 py-2 bg-white border border-slate-200 rounded-lg text-sm font-bold outline-none focus:ring-1 focus:ring-indigo-200 ehr-med-name">
                <input type="text" value="${m.dose||''}" placeholder="Dose" class="px-3 py-2 bg-white border border-slate-200 rounded-lg text-sm font-bold outline-none focus:ring-1 focus:ring-indigo-200 ehr-med-dose">
                <input type="text" value="${m.freq||''}" placeholder="Freq" class="px-3 py-2 bg-white border border-slate-200 rounded-lg text-sm font-bold outline-none focus:ring-1 focus:ring-indigo-200 ehr-med-freq">
            </div>`).join('');
            loading.classList.add('hidden');
            results.classList.remove('hidden');
            if (typeof lucide !== 'undefined') lucide.createIcons();
        } catch(e) {
            loading.classList.add('hidden');
            btn.disabled = false;
            errEl.textContent = 'Extraction failed: ' + (e.message||'Unknown error') + '. Try again or fill manually.';
            errEl.classList.remove('hidden');
        }
    }

