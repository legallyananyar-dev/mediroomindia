        this.patients = [];
        this.unsub = null;
        this.unsubChat = null;
        this.chatMessages = [];
        this.render();
        this.initFB();
    }

    async initFB() {
        try {
            const fbApp = initializeApp(FB);
            this.db = getFirestore(fbApp);
            const auth = getAuth(fbApp);
            await signInAnonymously(auth);
            this._fbReady = true;
            this._fbError = null;
            this.sync('live');
        } catch(e) {
            this._fbReady = false;
            this._fbError = e.code || e.message || 'Unknown Firebase error';
            console.error('Firebase init error:', e);
            this.sync('offline');
            // Re-render landing to show the error banner
            if (this.view === 'landing') this.render();
        }
    }

    sync(s) {
        const el = document.getElementById('sync-dot');
        if (!el) return;
        const m = {live:['bg-emerald-500','Synced'],saving:['bg-orange-400','Saving...'],offline:['bg-rose-400','Offline']};
        const [c,l] = m[s]||m.offline;
        el.innerHTML = `<div class="w-1.5 h-1.5 rounded-full ${c}"></div><span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">${l}</span>`;
    }

    async saveDoc(path, id, data) {
        this.sync('saving');
        try { await setDoc(doc(this.db, path, id), data, {merge:true}); this.sync('live'); return true; }
        catch(e) { this.sync('offline'); return false; }
    }

    logout() {
        if (this.unsub) this.unsub();
